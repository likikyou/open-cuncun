# 飞书开放平台配置
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_VERIFY_TOKEN=your_verify_token
FEISHU_ENCRYPT_KEY=your_encrypt_key

# AI 引擎配置
CEREBRAS_API_KEY=your_cerebras_key
CEREBRAS_API_BASE=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama-3.3-70b
DEEPSEEK_API_KEY=your_deepseek_key
CHATANYWHERE_API_KEY=your_chatanywhere_key
BOCHA_API_KEY=your_bocha_key
ALI_API_KEY=your_ali_key
# Groq 极速引擎（Llama，免费 tier）
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
# AI 引擎选择：cerebras（极速）/ groq（Llama，免费）/ deepseek（角色扮演强）
AI_PROVIDER=cerebras
# AI 超时与 provider 熔断：主模型连续失败后短时间跳过，直接走备用模型
AI_REQUEST_TIMEOUT_SECONDS=20
AI_CIRCUIT_ENABLED=true
AI_CIRCUIT_FAILURE_THRESHOLD=3
AI_CIRCUIT_WINDOW_SECONDS=60
AI_CIRCUIT_OPEN_SECONDS=300

# 机器人配置
BOT_NAME=Companion
DEEP_THINKING=false
ADMIN_OPEN_ID=your_open_id
# 配置后可通过 Authorization: Bearer <token> 查看 /health 全量观测详情；未配置时 /health 只返回脱敏摘要
HEALTH_AUTH_TOKEN=
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
DEBUG_MODE=false
INGRESS_MAX_WORKERS=3
EXECUTOR_MAX_WORKERS=5

# 默认天气位置（可选）
DEFAULT_WEATHER_LOCATION=中国北京
DEFAULT_WEATHER_PROVINCE=北京
DEFAULT_WEATHER_CITY=北京
DEFAULT_WEATHER_DISTRICT=北京
DEFAULT_LAT=39.90
DEFAULT_LON=116.41

# 定时任务
SCHEDULE_MORNING=09:00
SCHEDULE_NIGHT=00:00
SCHEDULE_BRUSH_TEETH=22:00
SCHEDULE_BACKUP=02:00
SCHEDULE_MEMORY_CONSOLIDATE=03:00
SCHEDULE_MEMORY_DECAY=04:00

# 记忆参数
MEMORY_FORGET_THRESHOLD=0.1
MEMORY_IMPORTANCE_PROTECT=0.5

# 路径覆盖（按需启用）
# DB_PATH=data/db/companion_memory.db
# PROMPT_PATH=data/prompts/example_prompt_template.txt
# ASSETS_PATH=data/voice_local
# VOICE_LIB=assets/voice
# MEMORY_PATH=data/db_local
# EMOTICON_DIR=emoticon
# LOG_FILE=logs/feishu-companion.log
# BACKUP_DIR=backups
